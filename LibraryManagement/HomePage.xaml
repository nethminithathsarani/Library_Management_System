<Page x:Class="LibraryManagement.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Home Page">

    <Grid>
        <StackPanel>
            <TextBlock Text="Welcome to the Library" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>

            <TextBlock Text="All Books" FontSize="18" FontWeight="Bold" Margin="10"/>
            <ListView Name="AllBooksList" Height="100"/>

            <TextBlock Text="Popular Books" FontSize="18" FontWeight="Bold" Margin="10"/>
            <ListView Name="PopularBooksList" Height="100"/>
        </StackPanel>
    </Grid>
</Page>
